{
  "extends": ["stylelint-config-standard"],
  "customSyntax": "postcss-scss",
  "rules": {
    "selector-pseudo-class-no-unknown": [
      true,
      { "ignorePseudoClasses": ["global", "local", "deep"] }
    ],
    "selector-class-pattern": [
      "^[a-z][a-zA-Z0-9]*(-{1,2}[a-z0-9]+)*$|^v-[a-z0-9_-]+$|^monaco[a-zA-Z0-9_-]*$|^cell-(drag|sortable|chosen)[a-z0-9-]*$|^xomda-[a-z0-9-]+$|^view-[a-z]+$|^cursors-[a-z]+$",
      {
        "message": "Class names use camelCase (modules) or kebab-case (Vuetify / Monaco / SortableJS / xomda-* hooks)"
      }
    ],
    "block-no-empty": true,
    "property-no-vendor-prefix": null,
    "declaration-no-important": null,
    "no-descending-specificity": null,
    "import-notation": "string",
    "alpha-value-notation": null,
    "color-function-notation": null,
    "color-function-alias-notation": null,
    "no-invalid-double-slash-comments": null,
    "comment-empty-line-before": null,
    "rule-empty-line-before": null,
    "shorthand-property-no-redundant-values": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "keyframes-name-pattern": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "use",
          "forward",
          "include",
          "mixin",
          "if",
          "else",
          "each",
          "for",
          "while",
          "function",
          "return",
          "extend",
          "import"
        ]
      }
    ]
  }
}
