{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "paths": {
      "@xomda/analysis-client": ["./packages/analysis/client/src/index.ts"],
      "@xomda/analysis-core": ["./packages/analysis/core/src/index.ts"],
      "@xomda/analysis-plugins": ["./packages/analysis/plugins/src/index.ts"],
      "@xomda/analysis-plugins-client": ["./packages/analysis/plugins-client/src/index.ts"],
      "@xomda/codeeditor": ["./packages/codeeditor/src/index.ts"],
      "@xomda/core": ["./packages/core/src/index.ts"],
      "@xomda/diagram": ["./packages/diagram/src/index.ts"],
      "@xomda/icons": ["./packages/icons/src/index.ts"],
      "@xomda/model": ["./packages/model/src/index.ts"],
      "@xomda/node": ["./packages/node/src/index.ts"],
      "@xomda/plugin-analysis-ant": ["./packages/analysis/ant/src/index.ts"],
      "@xomda/plugin-analysis-binary": ["./packages/analysis/binary/src/index.ts"],
      "@xomda/plugin-analysis-eslint": ["./packages/analysis/eslint/src/index.ts"],
      "@xomda/plugin-analysis-gradle": ["./packages/analysis/gradle/src/index.ts"],
      "@xomda/plugin-analysis-intellij": ["./packages/analysis/intellij/src/index.ts"],
      "@xomda/plugin-analysis-markdown": ["./packages/analysis/markdown/src/index.ts"],
      "@xomda/plugin-analysis-maven": ["./packages/analysis/maven/src/index.ts"],
      "@xomda/plugin-analysis-node": ["./packages/analysis/node/src/index.ts"],
      "@xomda/plugin-analysis-prettier": ["./packages/analysis/prettier/src/index.ts"],
      "@xomda/plugin-analysis-rust": ["./packages/analysis/rust/src/index.ts"],
      "@xomda/plugin-analysis-stylelint": ["./packages/analysis/stylelint/src/index.ts"],
      "@xomda/plugin-analysis-typescript": ["./packages/analysis/typescript/src/index.ts"],
      "@xomda/plugin-analysis-vite": ["./packages/analysis/vite/src/index.ts"],
      "@xomda/plugin-analysis-visualstudio": ["./packages/analysis/visualstudio/src/index.ts"],
      "@xomda/plugin-analysis-vscode": ["./packages/analysis/vscode/src/index.ts"],
      "@xomda/plugin-analysis-webpack": ["./packages/analysis/webpack/src/index.ts"],
      "@xomda/plugin-analysis-xomda": ["./packages/analysis/xomda/src/index.ts"],
      "@xomda/template": ["./packages/template/src/index.ts"],
      "@xomda/ui": ["./packages/ui/src/index.ts"],
      "@xomda/unplugin": ["./integrations/node/unplugin/src/index.ts"],
      "@xomda/util": ["./packages/util/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/dist/**", "**/target/**", "**/generated/**", "**/output/**"]
}
