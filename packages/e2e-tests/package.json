{
  "name": "@xomda/e2e-tests",
  "version": "0.0.1",
  "description": "End-to-end tests for xomda",
  "keywords": [
    "xomda",
    "e2e",
    "cypress"
  ],
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:app": "pnpm --filter @xomda/client build",
    "start:app": "pnpm --filter @xomda/node start --port 6440",
    "test": "pnpm build:app && start-server-and-test 'pnpm start:app' http-get://localhost:6440/trpc/template.list 'cypress run'",
    "test:cypress": "cypress run",
    "test:open": "pnpm build:app && start-server-and-test 'pnpm start:app' http-get://localhost:6440/trpc/template.list 'cypress open'"
  },
  "devDependencies": {
    "cypress": "15.14.2",
    "start-server-and-test": "3.0.4"
  }
}
