{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "paths": {
      "@xomda/codeeditor": ["../codeeditor/src/index.ts"],
      "@xomda/icons": ["../icons/src/index.ts"],
      "@xomda/model": ["../model/src/index.ts"],
      "@xomda/util": ["../util/src/index.ts"]
    },
    "types": ["node"],
    "declaration": true,
    "declarationDir": "dist",
    "rootDir": "../../"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.stories.*", "**/__tests__/**"]
}
