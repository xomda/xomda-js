{
  "name": "@xomda/ui",
  "version": "0.0.1",
  "private": true,
  "description": "Generic UI components for xomda",
  "keywords": [
    "xomda",
    "ui",
    "vue"
  ],
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6007",
    "build": "vite build",
    "build-storybook": "storybook build",
