    "vuetify": ">=4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vue/test-utils": "2.4.10",
    "happy-dom": "20.9.0",
    "pinia": "3.0.4",
    "type-fest": "^5.6.0",
    "vite": "8.0.10",
    "vite-plugin-dts": "5.0.0",
    "vue": "3.5.33",
    "vuetify": "4.0.6"
  }
