    "dequal": "2.0.3"
  },
  "peerDependencies": {
    "pinia": ">=3.0.0",
    "vue": ">=3.5.0",
    "vue-router": ">=4.0.0",
    "vuetify": ">=4.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/vue3": "10.4.0",
    "@storybook/vue3-vite": "10.4.0",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vue/test-utils": "2.4.10",
    "happy-dom": "20.9.0",
    "pinia": "3.0.4",
    "sass": "1.99.0",
    "storybook": "10.4.0",
    "type-fest": "^5.6.0",
    "vite": "8.0.13",
    "vite-plugin-dts": "5.0.0",
    "vue": "3.5.34",
    "vue-router": "5.0.7",
    "vuetify": "4.0.7"
  }
