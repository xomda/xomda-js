{
  "name": "@xomda/node",
  "version": "0.0.1",
  "description": "Node.js server for xomda",
  "keywords": [
    "xomda",
    "node"
  ],
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@trpc/server": "11.17.0",
    "@xomda/model": "workspace:*",
    "picocolors": "1.1.1",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@types/node": "25.7.0"
  }
}
