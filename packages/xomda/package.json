{
  "name": "@xomda/bundle",
  "version": "0.0.1",
  "private": true,
  "description": "Bundle harness for the published `xomda` npm package",
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:publish": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/build.ts",
    "test:tarball-cypress": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/tarball-cypress.ts",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@trpc/server": "11.17.0",
    "@xomda/cli": "workspace:*",
    "@xomda/node": "workspace:*",
    "@xomda/util": "workspace:*",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-dts": "5.0.0",
    "vitest": "4.1.7"
  }
}
