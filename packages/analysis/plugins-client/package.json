{
  "name": "@xomda/analysis-plugins-client",
  "version": "0.0.1",
  "private": true,
  "description": "Aggregator that imports every analysis plugin's client half so they self-register",
  "keywords": [
    "xomda",
    "analysis",
    "plugin",
    "client"
  ],
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "type": "module",
  "license": "MIT",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xomda/analysis-client": "workspace:*",
    "@xomda/analysis-core": "workspace:*",
    "@xomda/analysis-plugins": "workspace:*",
    "@xomda/plugin-analysis-ant": "workspace:*",
    "@xomda/plugin-analysis-binary": "workspace:*",
    "@xomda/plugin-analysis-eslint": "workspace:*",
    "@xomda/plugin-analysis-gradle": "workspace:*",
    "@xomda/plugin-analysis-intellij": "workspace:*",
    "@xomda/plugin-analysis-markdown": "workspace:*",
    "@xomda/plugin-analysis-maven": "workspace:*",
    "@xomda/plugin-analysis-node": "workspace:*",
    "@xomda/plugin-analysis-prettier": "workspace:*",
    "@xomda/plugin-analysis-rust": "workspace:*",
    "@xomda/plugin-analysis-stylelint": "workspace:*",
    "@xomda/plugin-analysis-typescript": "workspace:*",
    "@xomda/plugin-analysis-visualstudio": "workspace:*",
    "@xomda/plugin-analysis-vite": "workspace:*",
    "@xomda/plugin-analysis-vscode": "workspace:*",
    "@xomda/plugin-analysis-webpack": "workspace:*",
    "@xomda/plugin-analysis-xomda": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "happy-dom": "20.9.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
