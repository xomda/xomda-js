{
  "name": "@xomda/icons",
  "version": "0.0.1",
  "private": true,
  "description": "Icons for xomda",
  "keywords": [
    "xomda",
    "icons"
  ],
  "author": "Joris Aerts, 3611758+JorisAerts@users.noreply.github.com",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/generate.ts",
    "postinstall": "pnpm generate",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@iconify-json/material-symbols-light": "1.2.73",
    "devicon": "2.17.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
