<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
    <extension point="org.eclipse.ui.views">
        <category id="org.xomda.eclipse.views" name="Xomda"/>
        <view
            id="org.xomda.eclipse.views.XomdaView"
            name="Xomda Model"
            category="org.xomda.eclipse.views"
            class="org.xomda.eclipse.views.XomdaView"
            restorable="true"/>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <category id="org.xomda.eclipse.commands" name="Xomda"/>
        <command
            id="org.xomda.eclipse.commands.generate"
            name="Generate"
            categoryId="org.xomda.eclipse.commands"
            description="Run xomda code generation for the current project"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler
            commandId="org.xomda.eclipse.commands.generate"
            class="org.xomda.eclipse.handlers.GenerateHandler"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=window">
            <menu id="org.xomda.eclipse.menus.main" label="Xomda">
                <command
                    commandId="org.xomda.eclipse.commands.generate"
                    label="Generate"
                    style="push"/>
            </menu>
        </menuContribution>
    </extension>
</plugin>
