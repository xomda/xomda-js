{
  "name": "xomda.js",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @xomda/node --filter @xomda/client --parallel dev",
    "start": "pnpm --filter @xomda/node start",
    "build": "pnpm -r build",
    "build:jvm": "pnpm test:jvm:install-core && mvn -f integrations/jvm package -DskipTests -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo && gradle -p integrations/jvm/gradle build -x test && gradle -p integrations/jvm/intellij build -x test && MAVEN_OPTS=\"$MAVEN_OPTS -Djdk.xml.maxGeneralEntitySizeLimit=0 -Djdk.xml.totalEntitySizeLimit=0\" mvn -f integrations/jvm/eclipse package -DskipTests -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo",
    "build:all": "pnpm build && pnpm build:jvm",
    "clean:jvm": "mvn -f integrations/jvm clean -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo; mvn -f integrations/jvm/eclipse clean -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo; gradle -p integrations/jvm/gradle clean; gradle -p integrations/jvm/intellij clean; rm -rf integrations/jvm/.m2-repo",
    "clean:all": "pnpm clean:jvm && pnpm clean",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:jvm:install-core": "mvn -f integrations/jvm/generator-core install -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo -DskipTests",
    "test:jvm:maven": "mvn -f integrations/jvm verify",
    "test:jvm:gradle-plugin": "gradle -p integrations/jvm/gradle test",
    "test:jvm:intellij": "gradle -p integrations/jvm/intellij test",
    "test:jvm:eclipse": "MAVEN_OPTS=\"$MAVEN_OPTS -Djdk.xml.maxGeneralEntitySizeLimit=0 -Djdk.xml.totalEntitySizeLimit=0\" mvn -f integrations/jvm/eclipse verify -Dmaven.repo.local=$PWD/integrations/jvm/.m2-repo",
    "test:jvm": "pnpm test:jvm:install-core && pnpm test:jvm:maven && pnpm test:jvm:gradle-plugin && pnpm test:jvm:intellij && pnpm test:jvm:eclipse",
    "test:all": "pnpm -r test && pnpm test:jvm",
    "lint": "eslint . && pnpm lint:style",
    "lint:fix": "eslint . --fix && stylelint \"**/*.{css,scss}\" --ignore-path .gitignore --fix && prettier --write .",
    "lint:style": "stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
    "format": "prettier --write .",
    "lint-format-fix": "pnpm lint && pnpm lint:style && pnpm typecheck && pnpm test && pnpm build",
    "version:sync": "node scripts/sync-versions.js",
    "version:bump": "node scripts/bump-version.js",
    "version:bump:minor": "node scripts/bump-version.js minor",
    "version:bump:major": "node scripts/bump-version.js major"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "4.1.6",
    "@vue/tsconfig": "0.9.1",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "stylelint": "17.11.1",
    "stylelint-config-standard": "40.0.0",
    "type-fest": "^5.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
