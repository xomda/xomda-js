{
  "name": "xomda.js",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @xomda/node --filter @xomda/client --parallel dev",
    "start": "pnpm --filter @xomda/node start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:style": "stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
    "format": "prettier --write .",
    "lint-format-fix": "pnpm lint && pnpm lint:style && pnpm typecheck && pnpm test && pnpm build",
    "version:sync": "node scripts/sync-versions.js",
    "version:bump": "node scripts/bump-version.js",
    "version:bump:minor": "node scripts/bump-version.js minor",
    "version:bump:major": "node scripts/bump-version.js major"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cypress",
      "esbuild"
    ],
    "overrides": {
      "vue@>=2.0.0-alpha.1 <3.0.0-alpha.0": ">=3.0.0-alpha.0",
      "dompurify@<3.3.2": ">=3.3.2",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "dompurify@<=3.3.1": ">=3.3.2",
      "dompurify@<=3.3.3": ">=3.4.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "4.1.5",
    "@vue/tsconfig": "0.9.1",
    "@xmldom/xmldom": "^0.9.10",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "stylelint": "17.11.0",
    "stylelint-config-standard": "40.0.0",
    "type-fest": "^5.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
