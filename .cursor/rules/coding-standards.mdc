 * @param context - The data context for rendering
 * @returns The rendered output string
 * @throws If template compilation fails
 *
 * @example
 * const output = render('Hello {{name}}', { name: 'World' })
 */
export function render(templateStr: string, context: Record<string, unknown>): string {
  // ...
}
```

### README in Packages
- Purpose and primary use case
- Installation/usage examples
- Exported APIs/components
- Dependencies overview

### Inline Comments
- Only comment non-obvious logic
- Explain "why", not "what"
- Keep comments near the code they describe

```typescript
// Ôťů Good - Explains why
// Handlebars requires initialization only once to avoid re-registering helpers
if (!initialised) {
  registerHelpers(Handlebars)
  initialised = true
}

// ÔŁî Bad - Obvious from code
const x = 5  // Set x to 5
```

## Performance Considerations

### Vue 3
- Use `computed` for derived state (caching)
- Use `watchEffect` sparingly (can cause loops)
- Lazy-load components for large apps

### tRPC
- Batch related queries when possible
- Use queries for reads, mutations for writes
- Implement proper error handling

### Cell-based Templates
- Avoid nested loops inside `handlebars` cells (performance)
- Push expensive computation into a `logic` cell (runs once per render); `handlebars` cells just emit pre-computed strings
- The handlebars engine caches compilation per-string; identical cell content reuses the compiled template

## Security Best Practices

### User Input
- Always validate with Zod before processing
- Never trust client input for critical operations
- Sanitize template output if rendering user content

### Environment Variables
- Never commit `.env` files
- Use `.env.example` as template
- Document required variables in README

### Dependencies
- Review security advisories: `npm audit`
- Update regularly: `pnpm update`
- Check pnpm overrides for forced security versions

## Common Mistakes to Avoid

```typescript
// ÔŁî Using any
const data: any = fetchData()

// ÔŁî Mixed import types
import { User, getUserData } from '@xomda/core'  // should separate

// ÔŁî String concatenation
const msg = 'Hello ' + name + '!'  // should use template literal

// ÔŁî No return type
export function getModel() { }  // should have explicit return type

// ÔŁî Unused imports not prefixed
import { unused } from './utils'  // should start with _

// ÔŁî Default exports (outside tool config files)
export default defineComponent({ ... })  // use named export instead

// ÔŁî No Zod validation
function processUser(data: User) { }  // validate input first
```

